ALLOWED_HOSTS=yuksar.pizzacentergarden.uz,localhost,127.0.0.1
FRONTEND_URL=https://yuksar.pizzacentergarden.uz
SECURE_SSL_REDIRECT=True

# ── Database (PostgreSQL) ──────────────────────────────────────
